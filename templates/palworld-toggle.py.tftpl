#!/usr/bin/env python3
"""Palworld / Pal Editor toggle service.

A minimal HTTP server that lets you start and stop the Palworld game server
and the Pal Editor independently.  Communicates with the Docker daemon over
the unix socket.
"""

import http.client
import json
import socket
import threading
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse, parse_qs

DOCKER_SOCKET = "/var/run/docker.sock"
PALWORLD_CONTAINER = "palworld"
PALEDIT_CONTAINER = "paledit"
VALID_CONTAINERS = {PALWORLD_CONTAINER, PALEDIT_CONTAINER}


class DockerSocketConnection(http.client.HTTPConnection):
    """HTTPConnection subclass that talks to a unix socket."""

    def __init__(self, path):
        super().__init__("localhost")
        self.path = path

    def connect(self):
        self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.sock.connect(self.path)


def docker_request(method, path, body=None):
    conn = DockerSocketConnection(DOCKER_SOCKET)
    headers = {"Content-Type": "application/json"} if body else {}
    conn.request(method, path, body=body, headers=headers)
    resp = conn.getresponse()
    data = resp.read()
    status = resp.status
    conn.close()
    return status, data


def container_status(name):
    """Return the container state (running/exited/…) or 'unknown'."""
    status, data = docker_request("GET", f"/containers/{name}/json")
    if status == 200:
        info = json.loads(data)
        return info.get("State", {}).get("Status", "unknown")
    return "not found"


def container_logs(name, tail=5):
    """Return last N lines of container logs."""
    status, data = docker_request(
        "GET", f"/containers/{name}/logs?stdout=1&stderr=1&tail={tail}"
    )
    if status == 200:
        # Docker logs have 8-byte header per frame, strip them
        lines = []
        raw = data
        while len(raw) > 8:
            # First 4 bytes: stream type, next 4: size (big-endian)
            size = int.from_bytes(raw[4:8], "big")
            if size == 0 or len(raw) < 8 + size:
                break
            chunk = raw[8 : 8 + size].decode("utf-8", errors="replace").strip()
            if chunk:
                lines.append(chunk)
            raw = raw[8 + size :]
        # If framing didn't work (TTY mode), fall back to raw decode
        if not lines and data:
            lines = data.decode("utf-8", errors="replace").strip().splitlines()[-tail:]
        return lines[-tail:]
    return []


def stop_container(name):
    docker_request("POST", f"/containers/{name}/stop?t=30")


def start_container(name):
    docker_request("POST", f"/containers/{name}/start")


HTML_PAGE = """\
<!DOCTYPE html>
