</style>
</head>
<body>
  <h2>Palworld Server Control</h2>
  <div class="containers">
    <div class="container-card">
      <div class="label"><span class="dot" id="pw-dot"></span><span id="pw-label">Palworld: ...</span></div>
      <div class="actions">
        <button class="start" onclick="action('start','palworld')" id="pw-start">Start</button>
        <button class="stop" onclick="action('stop','palworld')" id="pw-stop">Stop</button>
      </div>
    </div>
    <div class="container-card">
      <div class="label"><span class="dot" id="pe-dot"></span><span id="pe-label">Pal Editor: ...</span></div>
      <div class="actions">
        <button class="start" onclick="action('start','paledit')" id="pe-start">Start</button>
        <button class="stop" onclick="action('stop','paledit')" id="pe-stop">Stop</button>
      </div>
    </div>
