  <div class="logs">
    <div class="log-section">
      <div class="log-title">Palworld Logs</div>
      <div class="log-lines" id="pw-logs">Loading...</div>
    </div>
    <div class="log-section">
      <div class="log-title">Pal Editor Logs</div>
      <div class="log-lines" id="pe-logs">Loading...</div>
    </div>
  </div>
<script>
  let polling = null;

  function updateUI(data) {
    const pw = data.palworld;
    const pe = data.paledit;

    document.getElementById('pw-dot').className = 'dot ' + (pw.status === 'running' ? 'running' : 'stopped');
    document.getElementById('pe-dot').className = 'dot ' + (pe.status === 'running' ? 'running' : 'stopped');
    document.getElementById('pw-label').textContent = 'Palworld: ' + pw.status;
    document.getElementById('pe-label').textContent = 'Pal Editor: ' + pe.status;

    document.getElementById('pw-start').disabled = pw.status === 'running';
    document.getElementById('pw-stop').disabled = pw.status !== 'running';
    document.getElementById('pe-start').disabled = pe.status === 'running';
    document.getElementById('pe-stop').disabled = pe.status !== 'running';

    document.getElementById('pw-logs').textContent = pw.logs.join('\\n') || '(no logs)';
    document.getElementById('pe-logs').textContent = pe.logs.join('\\n') || '(no logs)';
  }

  async function refresh() {
    try {
      const r = await fetch('/api/status');
      const data = await r.json();
      updateUI(data);
    } catch(e) {}
  }

  async function action(act, container) {
    // Disable all buttons during action
    document.querySelectorAll('button').forEach(b => { b.disabled = true; b.classList.add('loading'); });

    try {
      await fetch('/api/' + act + '/' + container, { method: 'POST' });
    } catch(e) {}

    // Start rapid polling for 10s to show logs updating
    document.querySelectorAll('button').forEach(b => b.classList.remove('loading'));
    if (polling) clearInterval(polling);
    polling = setInterval(refresh, 1000);
    setTimeout(() => { clearInterval(polling); polling = setInterval(refresh, 5000); }, 10000);

    refresh();
  }

  // Initial load and periodic refresh
  refresh();
  polling = setInterval(refresh, 5000);
</script>
</body>
</html>
"""


class ToggleHandler(BaseHTTPRequestHandler):

    def do_GET(self):
        if self.path == "/":
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(HTML_PAGE.encode())
            return

        if self.path == "/api/status":
            data = {
                "palworld": {
                    "status": container_status(PALWORLD_CONTAINER),
                    "logs": container_logs(PALWORLD_CONTAINER, 5),
                },
                "paledit": {
                    "status": container_status(PALEDIT_CONTAINER),
                    "logs": container_logs(PALEDIT_CONTAINER, 5),
                },
            }
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps(data).encode())
            return

        self.send_response(404)
        self.end_headers()

    def do_POST(self):
        parts = self.path.strip("/").split("/")
        # /api/start/<name> or /api/stop/<name>
        if len(parts) == 3 and parts[0] == "api" and parts[2] in VALID_CONTAINERS:
            name = parts[2]
            if parts[1] == "start":
                threading.Thread(target=start_container, args=(name,), daemon=True).start()
            elif parts[1] == "stop":
                threading.Thread(target=stop_container, args=(name,), daemon=True).start()
            else:
                self.send_response(404)
                self.end_headers()
                return

            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(b'{"ok":true}')
            return

        self.send_response(404)
        self.end_headers()

    def log_message(self, format, *args):
        print(f"[toggle] {args[0]}")


if __name__ == "__main__":
    server = HTTPServer(("0.0.0.0", 8090), ToggleHandler)
    print("[toggle] Listening on :8090")
    server.serve_forever()
