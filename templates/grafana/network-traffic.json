{
  "uid": "network-traffic",
  "title": "Network Traffic",
  "timezone": "browser",
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Network Bandwidth",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Upload" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device=~\"enp.*\"}[5m]) * 8",
          "legendFormat": "Download",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device=~\"enp.*\"}[5m]) * 8",
          "legendFormat": "Upload",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "schemaVersion": 39
}
